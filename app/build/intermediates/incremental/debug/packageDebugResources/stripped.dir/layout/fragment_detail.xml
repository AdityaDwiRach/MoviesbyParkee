<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="@dimen/spacing_16dp"
    tools:context=".presentation.detail.DetailFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv_detail"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_item_home_backdrop"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_backdrop"
                android:scaleType="centerCrop"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_16dp"
                android:layout_marginTop="@dimen/spacing_8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textSize="@dimen/title_size"
                android:textStyle="bold"
                tools:text="Title"
                app:layout_constraintTop_toBottomOf="@id/iv_item_home_backdrop"/>

            <TextView
                android:id="@+id/tv_detail_release_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_16dp"
                android:layout_marginTop="@dimen/spacing_8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textSize="@dimen/caption_size"
                app:layout_constraintTop_toBottomOf="@id/tv_detail_title"
                tools:text="Released - 2026" />

            <TextView
                android:id="@+id/tv_detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_16dp"
                android:layout_marginTop="@dimen/spacing_16dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/detail_description_title"
                android:textSize="@dimen/title_size"
                app:layout_constraintTop_toBottomOf="@id/tv_detail_release_date"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_item_favorite_overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_16dp"
                android:layout_marginTop="@dimen/spacing_8dp"
                android:ellipsize="end"
                android:maxLines="4"
                android:textSize="@dimen/description_size"
                app:layout_constraintTop_toBottomOf="@id/tv_detail_description"
                app:layout_constraintVertical_chainStyle="spread"
                tools:text="@string/lorem_ipsum" />

            <TextView
                android:id="@+id/tv_item_detail_review"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_16dp"
                android:layout_marginTop="@dimen/spacing_16dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/detail_review_title"
                android:textSize="@dimen/title_size"
                app:layout_constraintTop_toBottomOf="@id/tv_item_favorite_overview"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_detail_review"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_16dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tv_item_detail_review"
                tools:listitem="@layout/item_detail_review_adapter" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_detail_share"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_16dp"
                android:layout_marginEnd="@dimen/spacing_16dp"
                app:layout_constraintTop_toBottomOf="@id/rv_detail_review"
                android:src="@drawable/ic_share" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_detail_favorite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="@dimen/spacing_8dp"
                app:layout_constraintEnd_toStartOf="@id/iv_detail_share"
                app:layout_constraintTop_toTopOf="@id/iv_detail_share"
                app:layout_constraintBottom_toBottomOf="@id/iv_detail_share"
                android:src="@drawable/ic_favorite_off" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/detail_review_title" />

    <ProgressBar
        android:id="@+id/pg_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        tools:visibility="visible" />
</FrameLayout>